# 网关对外端口
GATEWAY_PORT=8080

# 外部 CPA（Zeabur）配置
EXTERNAL_CPA_BASE_URL=https://your-cpa.zeabur.app
EXTERNAL_CPA_MANAGEMENT_KEY=replace-with-your-management-key
CPA_AUTH_FILE_PREFIX=donate-geminicli

# 站点自身配置
ADMIN_PASSWORD=replace-with-your-admin-password
SESSION_SECRET=replace-with-a-long-random-secret
DATABASE_PATH=/app/data/donation-station.db

# 可选：公开站风控
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20

